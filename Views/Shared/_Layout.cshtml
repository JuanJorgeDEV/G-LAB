@{
    var nome = Context.Session.GetString("UsuarioNome");
    var perfil = Context.Session.GetString("UsuarioPerfil");
    var logado = !string.IsNullOrWhiteSpace(nome);
    var admin = perfil == "Administrador";
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "");
    var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? "");
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Triad Suport</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoOS.styles.css" asp-append-version="true" />
</head>
<body class="@(logado ? "app-body" : "auth-body")">
    @if (logado)
    {
        <div class="app-frame">
            <aside class="app-sidebar">
                <a class="brand-lockup" asp-controller="Home" asp-action="Index">
                    <img class="brand-logo-img" src="/images/logoSenai.png" alt="SENAI" />
                    <span>
                        <strong>Triad Suport</strong>
                        <small>G-Lab / SGMA-Web</small>
                    </span>
                </a>

                <nav class="side-nav" aria-label="Principal">
                    <a class="@(controller == "Home" && action == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
                        @(admin ? "Página Inicial" : "Minhas OS")
                    </a>
                    <a class="@(controller == "OrdensServico" && action == "Abrir" ? "active" : "")" asp-controller="OrdensServico" asp-action="Abrir">
                        <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14" /></svg></span> Nova OS
                    </a>
                    @* Aba Ordens: somente admin *@
                    @if (admin)
                    {
                        <a class="@(controller == "OrdensServico" && action != "Abrir" ? "active" : "")" asp-controller="OrdensServico" asp-action="Index">
                            <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h10" /></svg></span> Ordens
                        </a>
                        <a class="@(controller == "Equipamentos" ? "active" : "")" asp-controller="Equipamentos" asp-action="Index">
                            <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 7h16v10H4zM8 7V5h8v2M8 17v2h8v-2" /></svg></span> Equipamentos
                        </a>
                        <a class="@(controller == "Relatorios" ? "active" : "")" asp-controller="Relatorios" asp-action="Index">
                            <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 19V5M4 19h16M8 16v-5M12 16V8M16 16v-3" /></svg></span> Relatórios
                        </a>
                    }
                    <a class="@(controller == "Home" && action == "Ajuda" ? "active" : "")" asp-controller="Home" asp-action="Ajuda">
                        <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.75V16h8v-1.25A7 7 0 0 0 12 2z" /></svg></span> Ajuda
                    </a>
                    <a class="@(controller == "Home" && action == "Perfil" ? "active" : "")" asp-controller="Home" asp-action="Perfil">
                        <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" /></svg></span> Perfil
                    </a>
                </nav>

                <div class="side-account">
                    <small>@perfil</small>
                    <strong>@nome</strong>
                    <a asp-controller="Login" asp-action="Sair">
                        <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M10 17l5-5-5-5M15 12H3M21 3v18" /></svg></span> Sair
                    </a>
                </div>
            </aside>

            <div class="app-content">
                <header class="mobile-topbar">
                    <a class="mobile-brand" asp-controller="Home" asp-action="Index">
                        <img src="/images/logoSenai.png" alt="SENAI" />
                        <span>Triad Suport</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNav" aria-controls="mobileNav" aria-expanded="false" aria-label="Menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <nav class="collapse mobile-nav" id="mobileNav">
                        <a asp-controller="Home" asp-action="Index">
                            <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            @(admin ? "Página Inicial" : "Minhas OS")
                        </a>
                        <a asp-controller="OrdensServico" asp-action="Abrir">
                            <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                            Nova OS
                        </a>
                        @if (admin)
                        {
                            <a asp-controller="OrdensServico" asp-action="Index">
                                <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
                                Ordens
                            </a>
                            <a asp-controller="Equipamentos" asp-action="Index">
                                <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M4 7h16v10H4zM8 7V5h8v2M8 17v2h8v-2"/></svg>
                                Equipamentos
                            </a>
                            <a asp-controller="Relatorios" asp-action="Index">
                                <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M4 19V5M4 19h16M8 16v-5M12 16V8M16 16v-3"/></svg>
                                Relatórios
                            </a>
                        }
                        <a asp-controller="Home" asp-action="Ajuda">
                            <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.75V16h8v-1.25A7 7 0 0 0 12 2z"/></svg>
                            Ajuda
                        </a>
                        <a asp-controller="Home" asp-action="Perfil">
                            <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></svg>
                            Perfil
                        </a>
                        <a asp-controller="Login" asp-action="Sair">
                            <svg class="mobile-nav-icon" viewBox="0 0 24 24"><path d="M10 17l5-5-5-5M15 12H3M21 3v18"/></svg>
                            Sair
                        </a>
                    </nav>
                </header>

                <main class="app-main" role="main">
                    @if (TempData["Mensagem"] is not null)
                    {
                        <div class="alert alert-success">@TempData["Mensagem"]</div>
                    }
                    @if (TempData["Erro"] is not null)
                    {
                        <div class="alert alert-danger">@TempData["Erro"]</div>
                    }
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    &copy; 2026 - Triad Suport
                </footer>
            </div>
        </div>
    }
    else
    {
        <main class="auth-main" role="main">
            @RenderBody()
        </main>
        <footer class="auth-footer">
            &copy; 2026 - Triad Suport
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
