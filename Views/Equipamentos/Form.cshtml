@model Equipamento
@{
    ViewData["Title"] = Model.Id == 0 ? "Cadastrar equipamento" : "Editar equipamento";
}

<h1 class="h3 mb-4">@ViewData["Title"]</h1>

<form asp-action="Salvar" method="post" class="form-surface">
    <input type="hidden" asp-for="Id" />

    <div class="form-check form-switch mb-3">
        <input class="form-check-input" asp-for="PossuiNI" id="possuiNiSwitch" />
        <label class="form-check-label" for="possuiNiSwitch">Possui NI?</label>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-4">
            <label class="form-label">NI</label>
            <input class="form-control" asp-for="NI" />
            <span class="text-danger" asp-validation-for="NI"></span>
        </div>
        <div class="col-12 col-md-8">
            <label class="form-label">Nome</label>
            <input class="form-control" asp-for="Nome" required />
            <span class="text-danger" asp-validation-for="Nome"></span>
        </div>
        <div class="col-12">
            <label class="form-label">Descricao</label>
            <textarea class="form-control" asp-for="Descricao" rows="3"></textarea>
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">Localizacao</label>
            <input class="form-control" asp-for="Localizacao" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">Vinculo</label>
            <select class="form-select" asp-for="Vinculo">
                <option value="">Nao informado</option>
                <option>Aprendizagem</option>
                <option>FIC</option>
                <option>Outro</option>
            </select>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input class="form-check-input" asp-for="Ativo" />
                <label class="form-check-label">Ativo</label>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column flex-md-row gap-2 mt-4">
        <button class="btn btn-primary btn-lg" type="submit">Salvar</button>
        <a class="btn btn-outline-secondary btn-lg" asp-action="Index">Voltar</a>
    </div>
</form>
